# Staging runtime settings
WEB_PORT=8081

# Keep staging fully isolated from production data
PG_DATA_PATH=./data-staging/postgres
UPLOADS_PATH=./data-staging/uploads
BACKUP_DIR=./backups-staging
BACKUP_PREFIX=mainauto_staging

# PostgreSQL container bootstrap
POSTGRES_DB=mainauto_staging
POSTGRES_USER=mainauto_staging
POSTGRES_PASSWORD=replace-me

# Backend runtime
DATABASE_URL=postgresql://mainauto_staging:replace-me@postgres:5432/mainauto_staging?schema=public
BETTER_AUTH_SECRET=replace-with-long-random-secret
BACKEND_URL=https://staging-mainauto.rabauke.uk
CORS_ALLOWED_ORIGINS=https://staging-mainauto.rabauke.uk
COOKIE_DOMAIN=

# Initial admin bootstrap (set true only for first start)
BOOTSTRAP_ADMIN=false
INITIAL_ADMIN_USERNAME=mainauto
INITIAL_ADMIN_PASSWORD=replace-me
INITIAL_ADMIN_EMAIL=mainauto@admin.local

# Frontend build argument (empty = relative /api)
VITE_BACKEND_URL=
